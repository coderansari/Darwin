# Darwin dashboard — server-side env (Vercel: add these as Project Environment Variables)
#
# The dashboard renders static data with NO keys. These are ONLY for the optional
# live features (the "Evolve live" button and the live Fear & Greed badge).
# They are read SERVER-SIDE only and never shipped to the browser.
#
# NEVER prefix any of these with NEXT_PUBLIC_ — that would expose them publicly.

# Live "Evolve live" button — runs Claude as the GA's mutate operator.
ANTHROPIC_API_KEY=
# Optional: Anthropic-compatible gateway (e.g. DGRID). Omit to hit api.anthropic.com.
ANTHROPIC_BASE_URL=
# Optional: model id. Defaults to claude-opus-4-8. For the DGRID gateway use e.g.
# anthropic/claude-sonnet-4.6 to mirror the offline evolution engine.
DARWIN_MODEL=

# Live Fear & Greed badge — server-side CMC fetch.
CMC_PRO_API_KEY=

# DO NOT add BSC_PRIVATE_KEY, TWAK_ACCESS_ID, or TWAK_HMAC_SECRET here.
# Those are execution/wallet secrets and must never be deployed to a web app.
