# Copy to .env and fill in. NEVER commit .env.

# --- Claude (strategy generation + evolution) ---
ANTHROPIC_API_KEY=
# Runtime model. Sonnet is the cost/speed default for many evolution calls.
# Use claude-opus-4-8 for the final champion polish if you want max quality.
DARWIN_MODEL=claude-sonnet-4-6

# --- CoinMarketCap (market data + signals) ---
CMC_PRO_API_KEY=

# --- BNB Chain (TWAK execution + on-chain agent identity) ---
BSC_PRIVATE_KEY=
BSC_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545
BSC_CHAIN_ID=97
# Password to encrypt the local BNB Agent SDK keystore (testnet throwaway is fine).
WALLET_PASSWORD=darwin-testnet

# --- Trust Wallet Agent Kit portal API (portal.trustwallet.com) ---
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=
